#!/bin/sh
set -eu

SCRIPT_PATH=$0

while [ -L "$SCRIPT_PATH" ]; do
  LINK_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)
  SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
  case "$SCRIPT_PATH" in
    /*) ;;
    *) SCRIPT_PATH=$LINK_DIR/$SCRIPT_PATH ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)
DOTFILE_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/../../.." && pwd -P)
. "$DOTFILE_DIR/scripts/lib/logging.sh"

MODE=sync
AUTO_DISCOVER=0
packages=

usage() {
  cat <<'EOF'
Usage: dotsync [--unlink] [--auto-discover]

Without options, dotsync (re)links the managed dotfile packages using stow.

Options:
  --unlink  remove all managed dotfile symlinks for the active package set
  --auto-discover  compatibility no-op; stow handles link discovery
  -h, --help  show this help message
EOF
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

is_linux() {
  [ "$(uname -s)" = "Linux" ]
}

is_admin() {
  id -Gn 2>/dev/null | tr ' ' '\n' | grep -qx 'admin'
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

resolve_path() {
  path=$1

  if has_command realpath; then
    realpath "$path"
    return
  fi

  if has_command python3; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$path"
    return
  fi

  error "missing dependency 'realpath' or 'python3' for path resolution"
  exit 1
}

resolve_link_source() {
  target=$1
  source=$(readlink "$target" 2>/dev/null || printf '')

  case "$source" in
    "")
      return 1
      ;;
    /*)
      resolve_path "$source"
      ;;
    *)
      resolve_path "$(dirname "$target")/$source"
      ;;
  esac
}

remove_legacy_target_if_needed() {
  src=$1
  rel=$2
  target=$HOME/$rel

  [ -L "$target" ] || return 0

  current=$(resolve_link_source "$target" 2>/dev/null || printf '')
  [ -n "$current" ] || return 0

  expected=$(resolve_path "$src")
  if [ "$current" = "$expected" ]; then
    rm -f "$target"
    info "removed legacy symlink $rel"
  fi
}

prepare_legacy_links_for_stow() {
  package_name=$1
  package_dir=$DOTFILE_DIR/$package_name

  find "$package_dir" -mindepth 1 | LC_ALL=C sort | while IFS= read -r src; do
    rel=${src#$package_dir/}
    remove_legacy_target_if_needed "$src" "$rel"
  done
}

run_stow() {
  action=$1
  package_name=$2

  if [ "$action" = "-R" ]; then
    prepare_legacy_links_for_stow "$package_name"
  fi

  info "stow $action $package_name"
  (
    cd "$DOTFILE_DIR"
    if has_command stow; then
      stow "$action" "$package_name"
      exit 0
    fi

    if has_command nix-shell; then
      nix-shell -p stow --run "stow $action $package_name"
      exit 0
    fi

    error "missing dependency 'stow' for dotfile installation"
    exit 1
  )
}

parse_args() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --unlink)
        MODE=unlink
        ;;
      --auto-discover)
        AUTO_DISCOVER=1
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        error "unknown option: $1"
        usage >&2
        exit 1
        ;;
    esac
    shift
  done
}

select_packages() {
  packages="common"

  if is_macos; then
    packages="$packages macos"
    if is_admin; then
      packages="$packages nix-darwin"
    fi
  elif is_linux; then
    packages="$packages linux"
  fi
}

apply_packages() {
  action=-R
  if [ "$MODE" = "unlink" ]; then
    action=-D
  fi

  for package_name in $packages; do
    run_stow "$action" "$package_name"
  done
}

report_result() {
  if [ "$AUTO_DISCOVER" -eq 1 ]; then
    warn "--auto-discover is ignored in stow mode"
  fi

  if [ "$MODE" = "unlink" ]; then
    success "managed dotfile links removed"
  else
    success "dotfiles linked"
  fi
}

parse_args "$@"
select_packages
apply_packages
report_result
